# Copy to .env.yaml and fill values. Pass to gcloud with:
#   gcloud functions deploy whatsappWebhook --env-vars-file=.env.yaml ...
#
# YAML format requires VALUES to be quoted strings.

META_VERIFY_TOKEN: "replace_me_pick_any_long_random_string"
META_APP_SECRET: "replace_me_meta_app_secret"
META_ACCESS_TOKEN: "replace_me_long_token_starting_with_EAA"
META_PHONE_NUMBER_ID: "replace_me_15_digit_id"
SHEET_ID: "replace_me_sheet_id_from_url"

GRAPH_API_VERSION: "v18.0"
TZ: "Asia/Kolkata"
AFTERHOURS_START: "21"
AFTERHOURS_END: "8"
LAB_NAME: "Unique Janch Ghar"
