# Copy to .env (for local dev with functions-framework) or to .env.yaml
# (for `gcloud functions deploy --env-vars-file=.env.yaml`).
#
# .env format is KEY=VALUE.
# .env.yaml format is KEY: "VALUE" — see .env.yaml.example.
#
# NEVER commit either file. .gitignore already excludes them.

# ---- Required ----

# A string YOU pick. Paste the SAME string into Meta's Webhook Configuration
# page. Used only during the initial GET handshake.
META_VERIFY_TOKEN=replace_me_pick_any_long_random_string

# Meta App Secret. App Dashboard → Settings → Basic → "Show" next to App Secret.
# Used to verify the X-Hub-Signature-256 header on every POST.
META_APP_SECRET=replace_me_meta_app_secret

# Meta Cloud API access token. Use a System User permanent token in production
# (the temporary 24-hour token works for testing only).
META_ACCESS_TOKEN=replace_me_long_token_starting_with_EAA

# WhatsApp Manager → API Setup → "Phone number ID" (NOT the display number).
META_PHONE_NUMBER_ID=replace_me_15_digit_id

# Google Sheet ID — the long string between /d/ and /edit in the Sheet URL.
SHEET_ID=replace_me_sheet_id_from_url

# ---- Optional ----

# Graph API version. Bump only when Meta announces a breaking change.
GRAPH_API_VERSION=v18.0

# Timezone used for after-hours window calculation.
TZ=Asia/Kolkata

# Hour (0–23, local TZ) when after-hours auto-reply starts.
AFTERHOURS_START=21

# Hour (0–23, local TZ) when normal flow resumes the next morning.
AFTERHOURS_END=8

# Display name used in messages.
LAB_NAME=Unique Janch Ghar
